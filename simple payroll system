

name = input("Enter Name: ")
time = input("Press F for Full Time or P for Part Time ;) ")

# Declaring variables
rate = 150
perhour = 8
perday = 1800

# Result of user input
if time == "F":
    print("Name:", name)
    print("Monthly Salary:", 30 * perday)

elif time == "P":
    print("Enter rate per hour and no. hours he worked separated by space:")
    print(rate, perhour)
    print("Name:", name)
    print("Wage:", perhour * rate)

elif time == "f":
    print("Name:", name)
    print("Monthly Salary:", 30 * perday)

elif time == "p":
    print("Enter rate per hour and no. hours he worked separated by space:")
    print(rate, perhour)
    print("Name:", name)
    print("Wage:", perhour * rate)

else:
    print("State wether you are full time or part time, okay?!!!!")
